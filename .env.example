# ============================================================
#  그로잉업팀 대시보드 환경변수 템플릿
# ============================================================
# 사용법:
#   1. 이 파일을 ".env"로 복사
#   2. 실제 API 키 값 입력
#   3. 대시보드 재시작 시 자동 로드
#
# 보안:
#   - .env 파일은 .gitignore에 포함되어 있어 버전 관리에서 제외됩니다.
#   - API 키를 공유하거나 스크린샷에 노출하지 마세요.
# ============================================================

# --- 네이버 검색광고 API ---
# 발급: searchad.naver.com → 도구 → API 사용 관리
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# --- 네이버 커머스 API (스마트스토어) ---
# 발급 경로: apicenter.commerce.naver.com → 내 스토어 애플리케이션 → 등록
# 스토어별로 별도 애플리케이션 등록 후 각각 Client ID/Secret 발급
NAVER_COMMERCE_CLIENT_ID_DDOK=
NAVER_COMMERCE_CLIENT_SECRET_DDOK=
NAVER_COMMERCE_CLIENT_ID_ROLLA=
NAVER_COMMERCE_CLIENT_SECRET_ROLLA=

# --- 쿠팡 Wing API ---
# 발급: wing.coupang.com → 판매자 정보 → Open API 키 관리 → 발급
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# --- Cafe24 자사몰 API (OAuth 2.0) ---
# 발급: developers.cafe24.com → My Apps → Private App 생성
# 2개 스토어 (똑똑연구소, 롤라루)는 각각 앱 등록 필요
CAFE24_MALL_ID_DDOK=
CAFE24_CLIENT_ID_DDOK=
CAFE24_CLIENT_SECRET_DDOK=

CAFE24_MALL_ID_ROLLA=
CAFE24_CLIENT_ID_ROLLA=
CAFE24_CLIENT_SECRET_ROLLA=

# access/refresh token은 data/cafe24_tokens.json에 자동 저장됨 (gitignore)

# --- 메타 Marketing API (2개 광고 계정: 똑똑연구소 자사몰 / 롤라루 자사몰) ---
# 발급: developers.facebook.com → 앱 등록 → Marketing API 권한
META_ACCESS_TOKEN_DDOK=
META_AD_ACCOUNT_ID_DDOK=
META_ACCESS_TOKEN_ROLLA=
META_AD_ACCOUNT_ID_ROLLA=
